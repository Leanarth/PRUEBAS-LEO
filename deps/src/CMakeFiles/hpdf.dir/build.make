	@$(CMAKE_COMMAND) -E cmake_echo_color "--switch=$(COLOR)" --green --bold --progress-dir=/usr/libharu/CMakeFiles --progress-num=$(CMAKE_PROGRESS_60) "Linking C static library libhpdf.a"
	cd /usr/libharu/src && $(CMAKE_COMMAND) -P CMakeFiles/hpdf.dir/cmake_clean_target.cmake
	cd /usr/libharu/src && $(CMAKE_COMMAND) -E cmake_link_script CMakeFiles/hpdf.dir/link.txt --verbose=$(VERBOSE)

# Rule to build all files generated by this target.
src/CMakeFiles/hpdf.dir/build: src/libhpdf.a
.PHONY : src/CMakeFiles/hpdf.dir/build

src/CMakeFiles/hpdf.dir/clean:
	cd /usr/libharu/src && $(CMAKE_COMMAND) -P CMakeFiles/hpdf.dir/cmake_clean.cmake
.PHONY : src/CMakeFiles/hpdf.dir/clean

src/CMakeFiles/hpdf.dir/depend:
	cd /usr/libharu && $(CMAKE_COMMAND) -E cmake_depends "Unix Makefiles" /usr/libharu /usr/libharu/src /usr/libharu /usr/libharu/src /usr/libharu/src/CMakeFiles/hpdf.dir/DependInfo.cmake "--color=$(COLOR)" hpdf
.PHONY : src/CMakeFiles/hpdf.dir/depend

